# Managed by install_mosquitto.sh

# Listener / config paths
MOSQ_LISTENER_PORT=8883
MOSQ_BIND_ADDRESS=0.0.0.0
MOSQ_PLAINTEXT_BIND_ADDRESS=127.0.0.1
MOSQ_CONF_MAIN=/etc/mosquitto/mosquitto.conf
MOSQ_CONF_DIR=/etc/mosquitto/conf.d
MOSQ_PASSWORD_FILE=/etc/mosquitto/passwd
MOSQ_ACL_FILE=/etc/mosquitto/aclfile

# TLS files
# For username/password TLS only, certfile + keyfile are required.
# MOSQ_CA_FILE is only required when REQUIRE_CLIENT_CERT=true.
MOSQ_CERT_FILE=/etc/letsencrypt/live/mqtt.example.org/fullchain.pem
MOSQ_KEY_FILE=/etc/letsencrypt/live/mqtt.example.org/privkey.pem
# MOSQ_CA_FILE=/etc/ssl/certs/ca-certificates.crt

# Authentication / authorization
MOSQ_ALLOW_ANONYMOUS=false
MOSQ_ENABLE_ACL=true
WRITE_DEFAULT_ACL=true
ACL_TOPIC_PREFIX=watergauge/#

# Domain and TLS
DOMAIN=mqtt.woodsounds.org
EMAIL=admin@example.com

CREATE_DEVICE_USER=true
DEVICE_USER=watergauge
DEVICE_PASSWORD=your_device_password

CREATE_LOCAL_USER=true
LOCAL_USER=MQTTPlot
LOCAL_PASSWORD=your_local_password

MOSQ_ENABLE_ACL=true
WRITE_DEFAULT_ACL=true
ACL_TOPIC_PREFIX=watergauge/#

OPEN_PLAINTEXT_1883=true
MOSQ_PLAINTEXT_BIND_ADDRESS=127.0.0.1

# Logging / persistence
MOSQ_LOG_DEST=file
MOSQ_LOG_FILE=/var/log/mosquitto/mosquitto.log
MOSQ_PERSISTENCE=true
MOSQ_PERSISTENCE_LOCATION=/var/lib/mosquitto/

# Network exposure
UFW_ALLOW=true
OPEN_PLAINTEXT_1883=true
REQUIRE_CLIENT_CERT=false

# Let's Encrypt automation
LETSENCRYPT_ENABLE=true
LETSENCRYPT_DOMAIN=mqtt.example.org
LETSENCRYPT_EMAIL=admin@example.org
LETSENCRYPT_STAGING=false
LETSENCRYPT_FIX_DIR_PERMS=true

# Optional local-only test override
# TLS_CAFILE=/etc/ssl/certs/ca-certificates.crt
